---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout>
  <section class="shell hero minimal-hero">
    <div class="hero-copy">
      <p class="kicker">Koicosmos</p>
      <h1>Koicosmos</h1>
      <p class="lead">
        A quiet personal site for notes, language learning, and small interface experiments.
        For now, the clearest doorway is Sensus: an interactive reader for Latin and classical texts.
      </p>
      <div class="actions">
        <a class="button primary" href="https://sensus.koicosmos.com">Open Sensus</a>
        <a class="button" href="/blog/">Read notes</a>
      </div>
    </div>
    <aside class="quiet-panel" aria-label="Current focus">
      <p class="panel-label">Current focus</p>
      <h2>Sensus Classical Reader</h2>
      <p>
        Turning ancient text into something readable, clickable, and alive:
        grammar, syntax, translation, and context in one place.
      </p>
      <a href="https://sensus.koicosmos.com">Visit the project</a>
    </aside>
  </section>

  <section class="shell section">
    <div class="section-head">
      <h2>Notes</h2>
      <a class="muted" href="/archive/">View archive</a>
    </div>
    <div class="grid">
      {posts.map((post) => (
        <article class="entry-card">
          <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("en-US")}</time>
          <h3><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell section">
    <div class="section-head">
      <h2>Projects</h2>
      <a class="muted" href="/projects/">All projects</a>
    </div>
    <div class="grid">
      {projects.map((project) => (
        <article class="entry-card">
          <p class="meta">Project file</p>
          <h3><a href={`/projects/${project.slug}/`}>{project.data.title}</a></h3>
          <p>{project.data.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
