---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <article class="shell prose">
    <p class="kicker">Project file</p>
    <h1>{project.data.title}</h1>
    <p>{project.data.description}</p>
    {project.data.url && <p><a class="button primary" href={project.data.url}>Open project</a></p>}
    <Content />
  </article>
</BaseLayout>
