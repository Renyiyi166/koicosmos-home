---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects" description="Projects and experiments by Koicosmos, including Sensus Classical Reader.">
  <section class="shell section">
    <div class="section-head">
      <div>
        <p class="kicker">Evidence board</p>
        <h1>Projects</h1>
      </div>
    </div>
    <div class="grid">
      {projects.map((project) => (
        <article class="entry-card">
          <p class="meta">Project</p>
          <h3><a href={`/projects/${project.slug}/`}>{project.data.title}</a></h3>
          <p>{project.data.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
